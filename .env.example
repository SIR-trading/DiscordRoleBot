# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
GUILD_ID=
ADMIN_ROLE_ID=

# ── Tier configuration ───────────────────────────────────────────────────────
# Three comma-separated arrays, parallel by index, lowest → highest.
# Lengths must match. Thresholds in the token's native base units (decimal
# string, NOT scientific notation). SIR uses 12 decimals — each value below
# = <SIR amount> * 10^12.
#   100,000 SIR  →     100000000000000000  (17 zeros)
#   500,000,000 SIR → 500000000000000000000  (20 zeros)
TIER_NAMES=Gentleman,Squire,Knight,Baronet,Baron,Viscount,Earl,Marquess,Duke,Archduke,Grand Duke,Sovereign
TIER_ROLE_IDS=<id_gentleman>,<id_squire>,<id_knight>,<id_baronet>,<id_baron>,<id_viscount>,<id_earl>,<id_marquess>,<id_duke>,<id_archduke>,<id_grand_duke>,<id_sovereign>
TIER_THRESHOLDS_WEI=100000000000000000,250000000000000000,500000000000000000,1000000000000000000,2500000000000000000,5000000000000000000,10000000000000000000,25000000000000000000,50000000000000000000,100000000000000000000,200000000000000000000,500000000000000000000

# ── Chains ───────────────────────────────────────────────────────────────────
RPC_URL_ETH=https://eth-mainnet.g.alchemy.com/v2/<key>
RPC_URL_HYPER=https://hyperliquid-mainnet.g.alchemy.com/v2/<key>
RPC_URL_MEGA=https://megaeth-mainnet.g.alchemy.com/v2/<key>
SIR_PROXY_ETH=0xC046C450946E2d29703eb0299A32A647837f6D6C
SIR_PROXY_HYPER=0xD3d887c9bB931749aE38bA2E038d6E9261b2EE26
SIR_PROXY_MEGA=0x0dC7Bd0fe76B87485f308A68D2392E6EdC17c82f

# ── Verify web ───────────────────────────────────────────────────────────────
VERIFY_BASE_URL=https://verify.sir.trading
# WalletConnect/Reown project ID for verify-web RainbowKit (https://cloud.reown.com).
# NEXT_PUBLIC_* — inlined into the client bundle at build time, so changing this
# requires `docker compose build verify-web` (a restart is not enough). Add your
# verify domain (e.g. https://verify.sir.trading) to the project's Allowed
# Domains on cloud.reown.com or mobile users hit a 403 from api.web3modal.org.
# Leave blank to disable WalletConnect (injected wallets like MetaMask still work).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Runtime ──────────────────────────────────────────────────────────────────
DB_PATH=/data/sir.db
LOG_LEVEL=info
# How many wallets a single Discord user can link
MAX_WALLETS_PER_USER=5
# /verify rate limit
VERIFY_ATTEMPTS_PER_HOUR=3
# Nonce TTL (seconds)
NONCE_TTL_SECONDS=600
# Cron expression for the full refresh cycle
REFRESH_CRON=0 */6 * * *
# Chunk size for multicall batches
MULTICALL_CHUNK_SIZE=50
