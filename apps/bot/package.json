{
  "name": "@sir/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"const{mkdirSync,cpSync}=require('node:fs');mkdirSync('dist/db/migrations',{recursive:true});cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\"",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sir/shared": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "discord.js": "^14.16.3",
    "node-cron": "^3.0.3",
    "p-limit": "^6.1.0",
    "p-queue": "^8.0.1",
    "pino": "^9.5.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
